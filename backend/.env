# MongoDB Local Connection (default)
MONGODB_URI=mongodb://127.0.0.1:27017/kushal_hospitals
MONGO_URI=mongodb://127.0.0.1:27017/kushal_hospitals
FALLBACK_IN_MEMORY=true

# MongoDB Atlas Backup Connection (optional)
MONGODB_ATLAS_URI=

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret
JWT_SECRET=kushal_hospitals_super_secret_key_2026_enterprise_level

# JWT Expiry
JWT_EXPIRES_IN=7d

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# OTP Configuration
OTP_EXPIRY=10

# Pagination
ITEMS_PER_PAGE=10
